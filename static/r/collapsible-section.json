{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "collapsible-section",
	"type": "registry:ui",
	"title": "Collapsible Section",
	"description": "Collapsible Section component for Sequence UI.",
	"dependencies": [
		"svelte",
		"tailwind-merge"
	],
	"registryDependencies": [
		"chevron-icon"
	],
	"files": [
		{
			"path": "src/lib/components/primitives/CollapsibleSection.svelte",
			"content": "<script lang=\"ts\">\n\timport type { Snippet } from 'svelte';\n\n\timport { twMerge } from 'tailwind-merge';\n\timport ChevronIcon from '../icons/ChevronIcon.svelte';\n\n\ttype $$Props = {\n\t\ttitle: string;\n\t\tisOpen: boolean;\n\t\tclass?: string;\n\t\tontoggle?: () => void;\n\t\tcontentClass?: string;\n\t\tchildren?: Snippet;\n\t};\n\n\tlet {\n\t\ttitle,\n\t\tisOpen,\n\t\tclass: wrapperClass = '',\n\t\tontoggle,\n\t\tcontentClass = 'pad-box stack-field',\n\t\tchildren\n\t}: $$Props = $props();\n\n\tfunction handleClick() {\n\t\tif (ontoggle) {\n\t\t\tontoggle();\n\t\t}\n\t}\n\n\tconst sectionId = $derived(`section-content-${title.toLowerCase().replace(/\\s+/g, '-')}`);\n</script>\n\n<div class={twMerge(`border-b border-border overflow-hidden bg-background`, wrapperClass)}>\n\t<div\n\t\tclass=\"px-1 py-0.5 flex justify-between items-center cursor-pointer select-none bg-gradient-to-r from-muted to-panel border-border\"\n\t\tclass:border-b={isOpen}\n\t\tonclick={handleClick}\n\t\trole=\"button\"\n\t\ttabindex=\"0\"\n\t\taria-expanded={isOpen}\n\t\taria-controls={sectionId}\n\t\tonkeydown={(e) => {\n\t\t\tif (e.key === 'Enter' || e.key === ' ') {\n\t\t\t\te.preventDefault();\n\t\t\t\thandleClick();\n\t\t\t}\n\t\t}}\n\t>\n\t\t<h2 class=\"text-foreground type-title\">{title}</h2>\n\t\t<ChevronIcon direction={isOpen ? 'down' : 'right'} class=\"text-muted-foreground\" />\n\t</div>\n\n\t{#if isOpen}\n\t\t<div class={contentClass} id={sectionId}>\n\t\t\t{@render children?.()}\n\t\t</div>\n\t{/if}\n</div>\n",
			"type": "registry:ui",
			"target": "lib/components/primitives/CollapsibleSection.svelte"
		}
	]
}
