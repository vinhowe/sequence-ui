{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "panel",
	"type": "registry:ui",
	"title": "Panel",
	"description": "Panel component for Sequence UI.",
	"dependencies": [
		"svelte",
		"tailwind-merge"
	],
	"registryDependencies": [
		"citations",
		"katex-block"
