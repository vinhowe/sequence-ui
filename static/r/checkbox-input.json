{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "checkbox-input",
	"type": "registry:ui",
	"title": "Checkbox Input",
	"description": "Checkbox Input component for Sequence UI.",
	"dependencies": [],
	"registryDependencies": [
		"checkbox-icon",
		"citations",
		"katex-block",
		"reset-value-button"
	],
	"files": [
		{
			"path": "src/lib/components/controls/CheckboxInput.svelte",
			"content": "<script lang=\"ts\">\n\timport KatexBlock from '../optional/KatexBlock.svelte';\n\timport Citations, { type CitationEntries as CitationsType } from '../feedback/Citations.svelte';\n\timport CheckboxIcon from '../icons/CheckboxIcon.svelte';\n\timport ResetValueButton from './ResetValueButton.svelte';\n\n\ttype $$Props = {\n\t\tlabel?: string;\n\t\tchecked: boolean;\n\t\tcitations?: CitationsType;\n\t\tid: string;\n\t\tclass?: string;\n\t\tlabelClass?: string;\n\t\thasDefaultValue?: boolean;\n\t\tonReset?: () => void;\n\t};\n\n\tlet {\n\t\tlabel,\n\t\tcitations,\n\t\tchecked = $bindable(),\n\t\tid,\n\t\tclass: wrapperClass = '',\n\t\tlabelClass = 'type-body',\n\t\thasDefaultValue = false,\n\t\tonReset = undefined\n\t}: $$Props = $props();\n</script>\n\n<label\n\tfor={id}\n\tclass={`cursor-pointer select-none text-foreground grid grid-cols-[min-content_1fr] gap-x-1.25 shrink-0 ${wrapperClass}`.trim()}\n>\n\t<div class=\"relative inline-flex items-center self-center justify-self-start\">\n\t\t<input {id} type=\"checkbox\" bind:checked class=\"sr-only peer\" />\n\t\t<CheckboxIcon {checked} />\n\t</div>\n\n\t<div class=\"flex items-center justify-between gap-2 min-w-0\">\n\t\t{#if label}\n\t\t\t<span class={labelClass}>\n\t\t\t\t<KatexBlock text={label} />\n\t\t\t</span>\n\t\t{/if}\n\t\t{#if onReset}\n\t\t\t<ResetValueButton {hasDefaultValue} {onReset} />\n\t\t{/if}\n\t</div>\n\n\t{#if citations}\n\t\t<div class=\"col-start-2 row-start-2 leading-none\">\n\t\t\t<Citations {citations} />\n\t\t</div>\n\t{/if}\n</label>\n",
			"type": "registry:ui",
			"target": "lib/components/controls/CheckboxInput.svelte"
		}
	]
}
