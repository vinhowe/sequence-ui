{
	"$schema": "https://shadcn-svelte.com/schema/registry-item.json",
	"name": "note",
	"type": "registry:ui",
	"title": "Note",
	"description": "Note component for Sequence UI.",
	"dependencies": [
		"@lucide/svelte",
		"svelte",
		"tailwind-merge"
	],
	"registryDependencies": [
		"katex-block"
	],
	"files": [
		{
			"path": "src/lib/components/feedback/Note.svelte",
			"content": "<script lang=\"ts\">\n\timport type { Snippet } from 'svelte';\n\n\timport CircleAlertIcon from '@lucide/svelte/icons/circle-alert';\n\timport InfoIcon from '@lucide/svelte/icons/info';\n\timport TriangleAlertIcon from '@lucide/svelte/icons/triangle-alert';\n\n\timport KatexBlock from '../optional/KatexBlock.svelte';\n\timport { twMerge } from 'tailwind-merge';\n\n\ttype $$Props = {\n\t\tlabel: string;\n\t\ttype: 'info' | 'warning' | 'error';\n\t\tchildren: Snippet;\n\t};\n\n\tlet { label, type = 'info', children }: $$Props = $props();\n\n\tconst borderAndBackgroundClasses = $derived(\n\t\ttype === 'warning'\n\t\t\t? 'border-warning/60 bg-warning/15'\n\t\t\t: type === 'error'\n\t\t\t\t? 'border-destructive/60 bg-destructive/15'\n\t\t\t\t: 'border-border-strong/60 bg-card/50'\n\t);\n\n\tconst labelColorClass = $derived(\n\t\ttype === 'warning'\n\t\t\t? 'text-warning-strong'\n\t\t\t: type === 'error'\n\t\t\t\t? 'text-destructive-strong'\n\t\t\t\t: 'text-muted-foreground'\n\t);\n</script>\n\n<div\n\tclass={twMerge(\n\t\t'stack-tight p-1 text-foreground items-start border',\n\t\tborderAndBackgroundClasses\n\t)}\n>\n\t<span class={twMerge('flex items-center gap-1.25 type-label', labelColorClass)}>\n\t\t{#if type === 'info'}\n\t\t\t<InfoIcon class=\"w-3 h-3 shrink-0\" strokeWidth={2.8} />\n\t\t{:else if type === 'warning'}\n\t\t\t<TriangleAlertIcon class=\"w-3 h-3 shrink-0\" strokeWidth={2.8} />\n\t\t{:else if type === 'error'}\n\t\t\t<CircleAlertIcon class=\"w-3 h-3 shrink-0\" strokeWidth={2.8} />\n\t\t{/if}\n\t\t<KatexBlock text={label} />\n\t</span>\n\t<span class=\"type-body\">\n\t\t{@render children?.()}\n\t</span>\n</div>\n",
			"type": "registry:ui",
			"target": "lib/components/feedback/Note.svelte"
		}
	]
}
